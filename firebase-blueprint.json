{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user account",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "username": { "type": "string" },
        "email": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "profileViews": { "type": "number" },
        "visibility": { "type": "string", "enum": ["public", "private"] },
        "discordLinked": { "type": "boolean" },
        "discordUsername": { "type": "string" },
        "bannerStyle": { "type": "boolean" },
        "usernameStyle": { "type": "boolean" },
        "coins": { "type": "number", "description": "The user's coin balance" },
        "lastClaimedAt": { "type": "string", "format": "date-time", "description": "The last time the user claimed daily coins" }
      },
      "required": ["uid", "username", "email", "createdAt"]
    },
    "Profile": {
      "title": "Profile",
      "description": "A user's public profile data",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "username": { "type": "string" },
        "displayName": { "type": "string" },
        "bio": { "type": "string" },
        "backgroundUrl": { "type": "string" },
        "backgroundType": { "type": "string", "enum": ["video", "image", "color"] },
        "audioUrl": { "type": "string" },
        "avatarUrl": { "type": "string" },
        "cursorUrl": { "type": "string" },
        "petUrl": { "type": "string" },
        "usernameEffect": { "type": "string" },
        "backgroundEffect": { "type": "string" },
        "showStoreOnBio": { "type": "boolean", "description": "Whether to show the user's store items on their bio" },
        "links": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "title": { "type": "string" },
              "url": { "type": "string" },
              "icon": { "type": "string" }
            }
          }
        }
      },
      "required": ["uid", "username"]
    },
    "StoreItem": {
      "title": "StoreItem",
      "description": "An item for sale in the micro storefront",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "sellerId": { "type": "string" },
        "sellerUsername": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "type": { "type": "string", "enum": ["file", "template"] },
        "fileUrl": { "type": "string" },
        "templateData": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" },
        "sales": { "type": "number" }
      },
      "required": ["id", "sellerId", "name", "price", "type"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "A purchase transaction",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "buyerId": { "type": "string" },
        "sellerId": { "type": "string" },
        "itemId": { "type": "string" },
        "amount": { "type": "number" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "buyerId", "sellerId", "itemId", "amount", "timestamp"]
    },
    "ProfileView": {
      "title": "ProfileView",
      "description": "A single profile view record",
      "type": "object",
      "properties": {
        "profileId": { "type": "string", "description": "The UID of the profile viewed" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["profileId", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User account data"
    },
    "/profiles/{userId}": {
      "schema": { "$ref": "#/entities/Profile" },
      "description": "User profile data"
    },
    "/store_items/{itemId}": {
      "schema": { "$ref": "#/entities/StoreItem" },
      "description": "Store items for sale"
    },
    "/transactions/{transactionId}": {
      "schema": { "$ref": "#/entities/Transaction" },
      "description": "Purchase transactions"
    },
    "/profile_views/{viewId}": {
      "schema": { "$ref": "#/entities/ProfileView" },
      "description": "Historical profile views"
    },
    "/purchased_items/{userId}/items/{itemId}": {
      "schema": { "type": "object", "properties": { "itemId": { "type": "string" }, "purchasedAt": { "type": "string", "format": "date-time" } } },
      "description": "Items purchased by a user"
    },
    "/templates/{templateId}": {
      "schema": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "userId": { "type": "string" },
          "name": { "type": "string" },
          "data": { "type": "object" },
          "createdAt": { "type": "string", "format": "date-time" }
        },
        "required": ["id", "userId", "name", "data", "createdAt"]
      },
      "description": "User's private saved templates"
    }
  }
}
