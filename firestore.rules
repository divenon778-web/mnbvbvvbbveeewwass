rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function uidUnchanged() {
      return !('uid' in request.resource.data) || request.resource.data.uid == request.auth.uid;
    }
    
    function uidNotModified() {
      return !('uid' in request.resource.data) || request.resource.data.uid == resource.data.uid;
    }
    
    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }
    
    function isValidUser(data) {
      return data.uid is string &&
             data.username is string && data.username.size() > 0 && data.username.size() <= 30 &&
             data.email is string &&
             data.createdAt is string &&
             (!('profileViews' in data) || data.profileViews is number) &&
             (!('visibility' in data) || data.visibility in ['public', 'private']) &&
             (!('discordLinked' in data) || data.discordLinked is bool) &&
             (!('discordUsername' in data) || data.discordUsername is string) &&
             (!('bannerStyle' in data) || data.bannerStyle is bool) &&
             (!('usernameStyle' in data) || data.usernameStyle is bool) &&
             (!('coins' in data) || data.coins is number) &&
             (!('lastClaimedAt' in data) || data.lastClaimedAt is timestamp || data.lastClaimedAt is string);
    }
    
    function isValidUserUpdate(data, prevData) {
      return (isOwner(data.uid) && isValidUser(data)) ||
             (!isOwner(data.uid) && 
              request.resource.data.diff(resource.data).affectedKeys().hasOnly(['coins']) &&
              request.resource.data.coins > (resource.data.coins != null ? resource.data.coins : 0));
    }
    
    function isValidProfile(data) {
      return data.uid is string &&
             data.username is string && data.username.size() > 0 && data.username.size() <= 30 &&
             (!('displayName' in data) || data.displayName is string) &&
             (!('bio' in data) || data.bio is string) &&
             (!('backgroundUrl' in data) || data.backgroundUrl is string) &&
             (!('backgroundType' in data) || data.backgroundType in ['video', 'image', 'color']) &&
             (!('audioUrl' in data) || data.audioUrl is string) &&
             (!('avatarUrl' in data) || data.avatarUrl is string) &&
             (!('cursorUrl' in data) || data.cursorUrl is string) &&
             (!('petUrl' in data) || data.petUrl is string) &&
             (!('usernameEffect' in data) || data.usernameEffect is string) &&
             (!('backgroundEffect' in data) || data.backgroundEffect is string) &&
             (!('showStoreOnBio' in data) || data.showStoreOnBio is bool) &&
             (!('links' in data) || data.links is list) &&
             (!('profileViews' in data) || data.profileViews is number);
    }

    function isValidStoreItem(data) {
      return (!('id' in data) || data.id is string) &&
             data.sellerId is string &&
             (!('sellerUsername' in data) || data.sellerUsername is string) &&
             data.name is string && data.name.size() > 0 &&
             data.price is number && data.price >= 0 &&
             data.type in ['file', 'template'] &&
             (!('description' in data) || data.description is string) &&
             (!('fileUrl' in data) || data.fileUrl is string) &&
             (!('templateData' in data) || data.templateData is map) &&
             (!('sales' in data) || data.sales is number) &&
             (!('createdAt' in data) || data.createdAt is timestamp || data.createdAt is string);
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && hasRequiredFields(['uid', 'username', 'email', 'createdAt']) && isValidUser(request.resource.data) && uidUnchanged();
      allow update: if isAuthenticated() && isValidUserUpdate(request.resource.data, resource.data) && uidNotModified();
    }
    
    match /profiles/{userId} {
      allow read: if true; // Publicly readable for bio links
      allow create: if isOwner(userId) && hasRequiredFields(['uid', 'username']) && isValidProfile(request.resource.data) && uidUnchanged();
      allow update: if (isOwner(userId) && isValidProfile(request.resource.data) && uidNotModified()) ||
                       (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['profileViews']) && 
                        request.resource.data.profileViews == (resource.data.profileViews != null ? resource.data.profileViews : 0) + 1);
    }

    match /store_items/{itemId} {
      allow read: if true;
      allow create: if isAuthenticated() && request.auth.uid == request.resource.data.sellerId && isValidStoreItem(request.resource.data);
      allow update: if (isAuthenticated() && request.auth.uid == resource.data.sellerId && isValidStoreItem(request.resource.data)) ||
                       (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['sales']) && 
                        request.resource.data.sales == (resource.data.sales != null ? resource.data.sales : 0) + 1);
      allow delete: if isAuthenticated() && request.auth.uid == resource.data.sellerId;
    }

    match /transactions/{transactionId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.buyerId || request.auth.uid == resource.data.sellerId);
      allow create: if isAuthenticated() && request.auth.uid == request.resource.data.buyerId;
    }

    match /profile_views/{viewId} {
      allow read: if isAuthenticated() && request.auth.uid == resource.data.profileId;
      allow create: if request.resource.data.profileId is string && 
                      request.resource.data.timestamp is timestamp;
    }

    match /purchased_items/{userId}/items/{itemId} {
      allow read: if isOwner(userId);
      allow create, update: if isOwner(userId);
    }

    match /templates/{templateId} {
      allow read: if isAuthenticated() && request.auth.uid == resource.data.userId;
      allow create: if isAuthenticated() && request.auth.uid == request.resource.data.userId;
      allow update, delete: if isAuthenticated() && request.auth.uid == resource.data.userId;
    }
  }
}
